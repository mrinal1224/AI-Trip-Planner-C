rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function tripExists(tripId) {
      return exists(/databases/$(database)/documents/trips/$(tripId));
    }

    function isTripOwner(tripId) {
      return isSignedIn()
        && tripExists(tripId)
        && get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    // Users profile/preferences document
    match /users/{userId} {
      allow create: if isOwner(userId)
        && hasOnlyKeys(
          request.resource.data,
          [
            'name',
            'email',
            'budgetStyle',
            'tripType',
            'interests',
            'pace',
            'transportPreference',
            'createdAt',
            'updatedAt'
          ]
        )
        && request.resource.data.email is string;

      allow read: if isOwner(userId);

      allow update: if isOwner(userId)
        && hasOnlyKeys(
          request.resource.data,
          [
            'name',
            'email',
            'budgetStyle',
            'tripType',
            'interests',
            'pace',
            'transportPreference',
            'createdAt',
            'updatedAt'
          ]
        )
        // Keep email tied to authenticated user
        && request.resource.data.email == request.auth.token.email;

      allow delete: if isOwner(userId);
    }

    // Trips document owned by a user
    match /trips/{tripId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Query-friendly owner check for trip list/detail reads.
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if isTripOwner(tripId)
        // userId cannot be reassigned after create
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isTripOwner(tripId);

      // Itinerary days under a trip
      match /itineraryDays/{dayId} {
        allow create, read, update, delete: if isTripOwner(tripId);

        // Activities for each itinerary day
        match /activities/{activityId} {
          allow create, read, update, delete: if isTripOwner(tripId);
        }
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

